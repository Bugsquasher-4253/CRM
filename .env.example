# Copy this file to .env.production on the server and fill in real values
# NEVER commit .env.production to git

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
SITE_URL=https://your-domain.com

# Database (PostgreSQL on host — use host.docker.internal from inside Docker)
DATABASE_URL=postgres://hrms_user:your-db-password@host.docker.internal:5432/hrms

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
ADMIN_EMAIL=admin@yourcompany.com

# CSRF (add your domain)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
